# Copiez ce fichier vers .env à la racine du dépôt (ou placez .env dans linux/ / macOS/)
# et décommentez les lignes utiles. Ne commitez pas .env s’il contient des secrets.
#
# Syntaxe : shell (VAR=valeur ou export VAR=valeur). Pas d’espaces autour du =.

# NVM_INSTALL_TAG=latest
# FLUTTER_ROOT=$HOME/flutter
# DEV_SKIP_SHELL_RC=0
# DEV_SKIP_POSTGRES_SETUP=0
# POSTGRES_DEV_USER=dev
# POSTGRES_DEV_DB=devdb

# DEV_INSTALL_ANDROID_SDK=1
# DEV_ACCEPT_ANDROID_LICENSES=1
# ANDROID_SDK_ROOT=$HOME/Android/Sdk
# ANDROID_API=34
# ANDROID_BUILD_TOOLS=34.0.0

# Linux uniquement :
# DEV_ANDROID_STUDIO_USE_TARBALL=1
# ANDROID_STUDIO_LINUX_TARBALL_URL=https://...

# Fichier explicite (ignore la recherche automatique de .env) :
# DEV_ENV_FILE=$HOME/.config/script-dev.env
